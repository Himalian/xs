{
	"$schema": "https://cmake.org/cmake/help/latest/_downloads/3e2d73bff478d88a7de0de736ba5e361/schema.json",
	"version": 8,
	"configurePresets": [
		{
			"name": "base",
			"hidden": true,
			"generator": "Ninja"
		},
		{
			"name": "debug",
			"inherits": "base",
			"displayName": "Debug",
			"binaryDir": "${sourceDir}/build/debug",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug"
			}
		},
		{
			"name": "release",
			"inherits": "base",
			"displayName": "Release",
			"binaryDir": "${sourceDir}/build/release",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release"
			}
		}
	],
	"buildPresets": [
		{
			"name": "base",
			"hidden": true,
			"targets": "all"
		},
		{
			"name": "debug",
			"inherits": "base",
			"configurePreset": "debug"
		}
	]
}
